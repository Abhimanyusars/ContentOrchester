# Railway backend environment variables
# Copy these into Railway → your API service → Variables
# Repeat the same vars on the Worker service (except no PORT needed)

# ── Required ─────────────────────────────────────────
STANDALONE_MODE=false
APP_ENV=production
DEBUG=false

LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_from_console.groq.com
GROQ_MODEL=llama-3.1-8b-instant

TAVILY_API_KEY=tvly-your-key
JWT_SECRET=generate-with-openssl-rand-hex-32

# After adding Postgres + Redis plugins in Railway, reference them:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}

# Your Vercel URL (update after Vercel deploy)
CORS_ORIGINS=https://your-app.vercel.app

# ── Auto-set by Railway ──────────────────────────────
# PORT — set automatically, do not override
