# ── App ──────────────────────────────────────────────
APP_NAME=ContentForge
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

STANDALONE_MODE=false

# ── Ollama (free, local LLM — no API key needed) ──────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TIMEOUT_SECONDS=300

# ── Tavily (free tier: 1000 searches/month) ──────────
# Get your key at: https://tavily.com/
TAVILY_API_KEY=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
TAVILY_MAX_RESULTS=5

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=contentforge
POSTGRES_PASSWORD=contentforge
POSTGRES_DB=contentforge

# ── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
